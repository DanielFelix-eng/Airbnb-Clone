# MongoDB and server configuration
MONGO_DB=mongodb://username:password@host:port/dbname
PORT=3000
JWT_SECRET=your_jwt_secret
NODE_ENV=development
MAIL_TOKEN=your_mailtrap_token
MAIL_ENDPOINT=https://send.api.mailtrap.io/api/send
RESEND_API_KEY=your_resend_api_key

# Appwrite server-side upload configuration
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_appwrite_project_id
APPWRITE_BUCKET_ID=your_appwrite_bucket_id
APPWRITE_API_KEY=your_appwrite_api_key

# Frontend Vite environment variables (also used by the frontend)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your_appwrite_project_id
VITE_APPWRITE_BUCKET_ID=your_appwrite_bucket_id
